{
  "name": "japanese-os",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "generate:listening-audio": "tsx scripts/generate-listening-audio.ts",
    "preview": "vite preview",
    "report:build-status-summary": "node --import tsx scripts/report-build-status-summary.ts",
    "report:content-coverage": "node --import tsx scripts/report-content-coverage.ts",
    "report:content-overlap": "node --import tsx scripts/report-content-overlap.ts",
    "report:progression-gaps": "node --import tsx scripts/report-progression-gaps.ts",
    "report:reading-reuse": "node --import tsx scripts/report-reading-reuse.ts",
    "sync:listening-audio-manifest": "tsx scripts/sync-listening-audio-manifest.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "openai": "^6.34.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vite": "^7.0.0"
  }
}
